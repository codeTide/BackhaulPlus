#!/usr/bin/env bash
#
# bhp - BackhaulPlus interactive manager.
#
# This tool is INTERACTIVE ONLY. It does not accept direct subcommands.
# Running `bhp` opens a menu. Any arguments are ignored.
#
#   sudo bhp
#
# It manages installation, updates, the systemd service, config, logs,
# backups, and recovery. It never changes tunnel runtime behavior.

set -Eeuo pipefail

# --------------------------------------------------------------------------- #
# Constants / paths
# --------------------------------------------------------------------------- #
# Repository / branch can be overridden via environment variables. Useful for
# updating from a mirror when GitHub access is blocked or slow:
#   BHP_REPO_URL="https://mirror.example.com/codeTide/BackhaulPlus.git" bhp
REPO_URL="${BHP_REPO_URL:-https://github.com/codeTide/BackhaulPlus.git}"
REPO_BRANCH="${BHP_REPO_BRANCH:-main}"

BIN_DAEMON="/usr/local/bin/backhaulplus"
BIN_COMPAT="/usr/local/bin/BackhaulPlus"
BIN_MANAGER="/usr/local/bin/bhp"

CONFIG_DIR="/etc/backhaulplus"
CONFIG_FILE="${CONFIG_DIR}/config.toml"

STATE_DIR="/var/lib/backhaulplus"
SRC_DIR="${STATE_DIR}/src"

BACKUP_DIR="/var/backups/backhaulplus"

SERVICE_NAME="backhaulplus.service"
SERVICE_UNIT="/etc/systemd/system/${SERVICE_NAME}"

# Set to "yes" by do_update when the manager script itself was refreshed. Used
# by maybe_restart_manager to offer a self-restart so the new UI takes effect.
manager_updated="no"

# --------------------------------------------------------------------------- #
# Colors
# --------------------------------------------------------------------------- #
# supports_color: true when stdout is a TTY, tput exists, and the terminal
# advertises at least 8 colors. Honors NO_COLOR to disable colors entirely.
supports_color() {
	[[ -n "${NO_COLOR:-}" ]] && return 1
	[[ -t 1 ]] || return 1
	command -v tput >/dev/null 2>&1 || return 1
	[[ "$(tput colors 2>/dev/null || echo 0)" -ge 8 ]]
}

if supports_color; then
	C_RESET="$(tput sgr0)"
	C_BOLD="$(tput bold)"
	C_DIM="$(tput dim 2>/dev/null || true)"
	C_RED="$(tput setaf 1)"
	C_GREEN="$(tput setaf 2)"
	C_YELLOW="$(tput setaf 3)"
	C_BLUE="$(tput setaf 4)"
	C_MAGENTA="$(tput setaf 5)"
	C_CYAN="$(tput setaf 6)"
	C_BCYAN="$(tput setaf 14 2>/dev/null || tput setaf 6)"
else
	C_RESET=""; C_BOLD=""; C_DIM=""; C_RED=""; C_GREEN=""; C_YELLOW=""
	C_BLUE=""; C_MAGENTA=""; C_CYAN=""; C_BCYAN=""
fi

# --------------------------------------------------------------------------- #
# Layout helpers (separators, logo, headers)
# --------------------------------------------------------------------------- #
UI_WIDTH=64

# use_ascii: true when ASCII-safe separators should be used. Triggered by
# BHP_ASCII=1, a "dumb" terminal, or a non-UTF-8 locale.
use_ascii() {
	[[ "${BHP_ASCII:-0}" == "1" ]] && return 0
	[[ "${TERM:-}" == "dumb" ]] && return 0
	local enc="${LC_ALL:-${LC_CTYPE:-${LANG:-}}}"
	case "$enc" in
		*UTF-8*|*UTF8*|*utf-8*|*utf8*) return 1 ;;
		"") return 0 ;;
		*) return 0 ;;
	esac
}

# sep: print a full-width colored separator line.
sep() {
	local ch line
	if use_ascii; then ch="-"; else ch="━"; fi
	# Build the line with the chosen character repeated UI_WIDTH times.
	if use_ascii; then
		line="$(printf '%*s' "$UI_WIDTH" '' | tr ' ' '-')"
	else
		line=""
		local i
		for ((i = 0; i < UI_WIDTH; i++)); do line+="$ch"; done
	fi
	printf '%s%s%s\n' "$C_CYAN" "$line" "$C_RESET"
}

# print_logo: large ASCII project title for the main menu.
print_logo() {
	printf '%s%s' "$C_BCYAN" "$C_BOLD"
	cat <<'EOF'
  ____             _    _                 _ ____  _
 | __ )  __ _  ___| | _| |__   __ _ _   _| |  _ \| |_   _ ___
 |  _ \ / _` |/ __| |/ / '_ \ / _` | | | | | |_) | | | | / __|
 | |_) | (_| | (__|   <| | | | (_| | |_| | |  __/| | |_| \__ \
 |____/ \__,_|\___|_|\_\_| |_|\__,_|\__,_|_|_|   |_|\__,_|___/
EOF
	printf '%s' "$C_RESET"
}

# label_value: print " Label : value" with colored label and value.
label_value() {
	local label="$1" value="$2" vcol="${3:-}"
	printf ' %s%-8s%s: %s%s%s\n' \
		"$C_BOLD" "$label" "$C_RESET" "${vcol}" "$value" "$C_RESET"
}

# status_color: echo the ANSI color appropriate for a service status word.
status_color() {
	case "$1" in
		running|up-to-date)  printf '%s' "$C_GREEN" ;;
		stopped|behind*)     printf '%s' "$C_YELLOW" ;;
		failed|diverged)     printf '%s' "$C_RED" ;;
		ahead*)              printf '%s' "$C_YELLOW" ;;
		*)                   printf '%s' "$C_MAGENTA" ;;
	esac
}

# menu_item: render a single colored menu choice.
#   $1 = number/key, $2 = label text, $3 = optional label color (defaults bold).
# The number is always cyan; the label uses the requested color so destructive
# or advanced options can stand out. No emojis; degrades to plain text when
# colors are disabled (all C_* expand to empty).
menu_item() {
	local num="$1" text="$2" color="${3:-$C_BOLD}"
	printf '  %s%s.%s %s%s%s\n' "$C_CYAN" "$num" "$C_RESET" "$color" "$text" "$C_RESET"
}

info()  { printf '%s==>%s %s\n' "${C_BLUE}${C_BOLD}" "${C_RESET}" "$*"; }
ok()    { printf '%s[ ok ]%s %s\n' "${C_GREEN}" "${C_RESET}" "$*"; }
warn()  { printf '%s[warn]%s %s\n' "${C_YELLOW}" "${C_RESET}" "$*"; }
err()   { printf '%s[fail]%s %s\n' "${C_RED}${C_BOLD}" "${C_RESET}" "$*" >&2; }

timestamp() { date +%Y%m%d-%H%M%S; }

# --------------------------------------------------------------------------- #
# Prompt helpers
# --------------------------------------------------------------------------- #
pause() {
	printf '\n'
	read -r -p "Press Enter to continue..." _ || true
}

ask_yes_no() {
	local prompt="$1" default="${2:-y}" reply
	local hint="[Y/n]"
	[[ "$default" == "n" ]] && hint="[y/N]"
	read -r -p "$(printf '%s %s ' "$prompt" "$hint")" reply || reply=""
	reply="${reply:-$default}"
	[[ "$reply" =~ ^[Yy]$ ]]
}

# Require root for actions that modify state. Read-only menus call this with
# "soft" to only warn.
require_root() {
	if [[ "$(id -u)" -ne 0 ]]; then
		err "This action requires root. Run: sudo bhp"
		return 1
	fi
	return 0
}

# --------------------------------------------------------------------------- #
# Git authentication helpers (private repository support)
# --------------------------------------------------------------------------- #
# These helpers allow git network operations (clone/fetch/pull) to authenticate
# against a private GitHub repository using a token, without ever printing the
# token, writing it to logs, or persisting it in the remote URL / .git/config.
#
# Token sources, in order:
#   1. BHP_GITHUB_TOKEN environment variable
#   2. BHP_GIT_TOKEN environment variable (alias)
#   3. Interactive (no-echo) prompt, only when a git operation fails and stdin
#      is a TTY.

# get_git_token_interactive: print a token on stdout (or nothing). Prefers the
# environment variables; otherwise prompts the user without echoing input.
get_git_token_interactive() {
	local token=""
	if [[ -n "${BHP_GITHUB_TOKEN:-}" ]]; then
		printf '%s' "$BHP_GITHUB_TOKEN"
		return
	fi
	if [[ -n "${BHP_GIT_TOKEN:-}" ]]; then
		printf '%s' "$BHP_GIT_TOKEN"
		return
	fi

	if [[ -t 0 ]]; then
		if ask_yes_no "Git authentication may be required. Enter a GitHub token now?" "n"; then
			read -r -s -p "GitHub token: " token
			printf '\n' >&2
			printf '%s' "$token"
		fi
	fi
}

# run_git_with_token: run a git command authenticating with the given token via
# a temporary GIT_ASKPASS helper. The token is passed only through the
# environment for the single invocation and never written to disk in cleartext
# git config. The askpass script is removed afterwards.
run_git_with_token() {
	local token="$1"
	shift

	local askpass
	askpass="$(mktemp)"
	chmod 700 "$askpass"
	cat > "$askpass" <<'EOF'
#!/usr/bin/env sh
case "$1" in
  *Username*) echo "x-access-token" ;;
  *Password*) echo "$BHP_EFFECTIVE_GIT_TOKEN" ;;
  *) echo "" ;;
esac
EOF

	BHP_EFFECTIVE_GIT_TOKEN="$token" \
	GIT_ASKPASS="$askpass" \
	GIT_TERMINAL_PROMPT=0 \
		"$@"

	local rc=$?
	rm -f "$askpass"
	return "$rc"
}

# git_run: run a git network command. On failure, offer token-authenticated
# retry. Use ONLY for operations that may hit the network (clone/fetch/pull).
# Never use it for local-only commands (rev-parse, merge-base, etc.).
git_run() {
	if "$@"; then
		return 0
	fi

	local rc=$?
	warn "Git command failed. Authentication or network access may be required."

	local token
	token="$(get_git_token_interactive)"
	if [[ -n "$token" ]]; then
		info "Retrying git command with token authentication..."
		run_git_with_token "$token" "$@"
		return $?
	fi

	return "$rc"
}

# --------------------------------------------------------------------------- #
# Status / version helpers
# --------------------------------------------------------------------------- #
service_status() {
	if [[ ! -f "$SERVICE_UNIT" ]]; then
		printf 'not installed'
		return
	fi
	if systemctl is-active --quiet "$SERVICE_NAME"; then
		printf 'running'
	elif systemctl is-failed --quiet "$SERVICE_NAME"; then
		printf 'failed'
	else
		printf 'stopped'
	fi
}

binary_version() {
	# Prefer the source commit; fall back to the binary's -v output.
	local ver=""
	if [[ -d "${SRC_DIR}/.git" ]] && command -v git >/dev/null 2>&1; then
		local branch commit
		branch="$(git -C "$SRC_DIR" rev-parse --abbrev-ref HEAD 2>/dev/null || echo '?')"
		commit="$(git -C "$SRC_DIR" rev-parse --short HEAD 2>/dev/null || echo '?')"
		ver="${branch} ${commit}"
	elif [[ -x "$BIN_DAEMON" ]]; then
		ver="$("$BIN_DAEMON" -v 2>/dev/null | head -n1 || true)"
	fi
	[[ -z "$ver" ]] && ver="unknown"
	printf '%s' "$ver"
}

# --------------------------------------------------------------------------- #
# Backup helpers
# --------------------------------------------------------------------------- #
ensure_backup_dir() { install -d -m 0750 "$BACKUP_DIR"; }

backup_config() {
	ensure_backup_dir
	if [[ -f "$CONFIG_FILE" ]]; then
		local dest="${BACKUP_DIR}/config-$(timestamp).toml"
		cp -a "$CONFIG_FILE" "$dest"
		ok "Config backed up to ${dest}"
	else
		warn "No config at ${CONFIG_FILE} to back up."
	fi
}

# Machine-readable: prints ONLY the backup path (or nothing) on stdout.
# Safe to use in command substitution.
backup_binary_path() {
	ensure_backup_dir
	if [[ -f "$BIN_DAEMON" ]]; then
		local dest="${BACKUP_DIR}/backhaulplus-$(timestamp)"
		cp -a "$BIN_DAEMON" "$dest"
		printf '%s\n' "$dest"
	else
		printf ''
	fi
}

# UI-oriented wrapper. Prints human messages; not for command substitution.
backup_binary() {
	local dest
	dest="$(backup_binary_path)"
	if [[ -n "$dest" ]]; then
		ok "Binary backed up to ${dest}"
	else
		warn "No binary at ${BIN_DAEMON} to back up."
	fi
}

backup_all() {
	ensure_backup_dir
	local ts; ts="$(timestamp)"
	local workdir; workdir="$(mktemp -d)"
	local meta="${workdir}/metadata.txt"

	{
		printf 'date: %s\n' "$(date -Is)"
		if [[ -d "${SRC_DIR}/.git" ]]; then
			printf 'git_commit: %s\n' "$(git -C "$SRC_DIR" rev-parse HEAD 2>/dev/null || echo unknown)"
		else
			printf 'git_commit: unknown\n'
		fi
		printf 'binary_path: %s\n' "$BIN_DAEMON"
		printf 'config_path: %s\n' "$CONFIG_FILE"
		printf 'service_status: %s\n' "$(service_status)"
	} > "$meta"

	local files=("$meta")
	[[ -f "$CONFIG_FILE" ]]  && cp -a "$CONFIG_FILE"  "${workdir}/config.toml"
	[[ -f "$BIN_DAEMON" ]]   && cp -a "$BIN_DAEMON"   "${workdir}/backhaulplus"
	[[ -f "$SERVICE_UNIT" ]] && cp -a "$SERVICE_UNIT" "${workdir}/${SERVICE_NAME}"

	local tarball="${BACKUP_DIR}/full-${ts}.tar.gz"
	( cd "$workdir" && tar -czf "$tarball" . )
	rm -rf "$workdir"
	ok "Full backup created at ${tarball}"
}

# --------------------------------------------------------------------------- #
# Service helpers
# --------------------------------------------------------------------------- #
recreate_symlink() { ln -sf "$BIN_DAEMON" "$BIN_COMPAT"; }

health_check() {
	sleep 1
	systemctl is-active --quiet "$SERVICE_NAME"
}

# --------------------------------------------------------------------------- #
# Git status helpers
# --------------------------------------------------------------------------- #
# git_current_short: short SHA of the local HEAD (or "?" if unavailable).
git_current_short() {
	git -C "$SRC_DIR" rev-parse --short HEAD 2>/dev/null || printf '?'
}

# git_remote_short: short SHA of origin/<branch> (or "?" if unavailable).
git_remote_short() {
	git -C "$SRC_DIR" rev-parse --short "origin/${REPO_BRANCH}" 2>/dev/null || printf '?'
}

# git_update_status: classify local checkout vs origin/<branch>.
# Prints one of: up-to-date, behind remote, ahead of remote, diverged, unknown.
git_update_status() {
	local local_sha remote_sha base_sha
	local_sha="$(git -C "$SRC_DIR" rev-parse HEAD 2>/dev/null || true)"
	remote_sha="$(git -C "$SRC_DIR" rev-parse "origin/${REPO_BRANCH}" 2>/dev/null || true)"
	if [[ -z "$local_sha" || -z "$remote_sha" ]]; then
		printf 'unknown'; return
	fi
	base_sha="$(git -C "$SRC_DIR" merge-base HEAD "origin/${REPO_BRANCH}" 2>/dev/null || true)"
	if [[ "$local_sha" == "$remote_sha" ]]; then
		printf 'up-to-date'
	elif [[ "$local_sha" == "$base_sha" ]]; then
		printf 'behind remote'
	elif [[ "$remote_sha" == "$base_sha" ]]; then
		printf 'ahead of remote'
	else
		printf 'diverged'
	fi
}

# print_update_preview: render the colored update preview block.
# Args: status
print_update_preview() {
	local status="$1"
	local svc; svc="$(service_status)"
	sep
	printf ' %s%sUpdate preview%s\n' "$C_BOLD" "$C_CYAN" "$C_RESET"
	sep
	label_value "Repo"    "$REPO_URL"            "$C_DIM"
	label_value "Branch"  "$REPO_BRANCH"         "$C_CYAN"
	label_value "Local"   "$(git_current_short)" "$C_CYAN"
	label_value "Remote"  "$(git_remote_short)"  "$C_CYAN"
	label_value "Status"  "$status"              "$(status_color "$status")"
	label_value "Service" "$svc"                 "$(status_color "$svc")"
	sep
}

# --------------------------------------------------------------------------- #
# Update / build
# --------------------------------------------------------------------------- #
# ensure_origin_url: point the existing checkout's origin at the configured
# REPO_URL so BHP_REPO_URL overrides apply to existing clones (mirror support),
# not just fresh clones.
ensure_origin_url() {
	if [[ -d "${SRC_DIR}/.git" ]]; then
		if git -C "$SRC_DIR" remote get-url origin >/dev/null 2>&1; then
			git -C "$SRC_DIR" remote set-url origin "$REPO_URL"
		else
			git -C "$SRC_DIR" remote add origin "$REPO_URL"
		fi
	fi
}

# ensure_source: make sure a source checkout exists; clone it if missing.
ensure_source() {
	if [[ -d "${SRC_DIR}/.git" ]]; then
		return 0
	fi
	info "Cloning source..."
	install -d -m 0755 "$STATE_DIR"
	rmdir "$SRC_DIR" 2>/dev/null || true
	git_run git clone --branch "$REPO_BRANCH" "$REPO_URL" "$SRC_DIR"
}

# fetch_source: fetch the configured remote branch (no working-tree changes).
# Uses an explicit refspec so origin/<branch> is always refreshed for the
# update preview / status logic, not just FETCH_HEAD.
fetch_source() {
	ensure_origin_url
	info "Fetching origin/${REPO_BRANCH}..."
	git_run git -C "$SRC_DIR" fetch --prune origin \
		"+refs/heads/${REPO_BRANCH}:refs/remotes/origin/${REPO_BRANCH}"
}

# apply_update: fast-forward the local checkout. Returns non-zero on failure
# without making destructive changes (no reset --hard).
apply_update() {
	ensure_origin_url
	git -C "$SRC_DIR" checkout "$REPO_BRANCH" || return 1
	git_run git -C "$SRC_DIR" pull --ff-only origin "$REPO_BRANCH" || return 1
}

# install_manager_atomic: install the updated manager script from the source
# checkout over /usr/local/bin/bhp. Replacing the file while the old script is
# running is safe; the current process keeps using the open file and the next
# `bhp` invocation picks up the new one.
install_manager_atomic() {
	local src_manager="${SRC_DIR}/scripts/bhp"
	if [[ -f "$src_manager" ]]; then
		install -m 0755 "$src_manager" "${BIN_MANAGER}.new"
		mv -f "${BIN_MANAGER}.new" "$BIN_MANAGER"
		ok "Manager updated at ${BIN_MANAGER}"
		return 0
	fi
	warn "Manager script not found at ${src_manager}; manager was not updated."
	return 1
}

# update_source: used by Install / Repair. Clone or fast-forward only.
update_source() {
	if [[ -d "${SRC_DIR}/.git" ]]; then
		info "Updating source checkout..."
		ensure_origin_url
		git_run git -C "$SRC_DIR" fetch --prune origin \
			"+refs/heads/${REPO_BRANCH}:refs/remotes/origin/${REPO_BRANCH}"
		apply_update
	else
		ensure_source
	fi
}

build_binary() {
	# Build into a temp file; echo the path on success, non-zero on failure.
	local tmpdir out
	tmpdir="$(mktemp -d /tmp/backhaulplus-build.XXXXXX)"
	out="${tmpdir}/backhaulplus"
	info "Building daemon..." >&2
	if ( cd "$SRC_DIR" && go build -o "$out" . ); then
		printf '%s\n' "$out"
	else
		rm -rf "$tmpdir"
		return 1
	fi
}

install_binary_atomic() {
	local built="$1"
	install -m 0755 "$built" "${BIN_DAEMON}.new"
	mv -f "${BIN_DAEMON}.new" "$BIN_DAEMON"
	recreate_symlink
}

do_update() {
	require_root || { pause; return; }
	if ! command -v go >/dev/null 2>&1 || ! command -v git >/dev/null 2>&1; then
		err "git and go are required to update. Install them and retry."
		pause; return
	fi

	# 1. Ensure the source checkout exists (clone if missing).
	if ! ensure_source; then
		err "Could not prepare source checkout at ${SRC_DIR}."
		pause; return
	fi

	# 2. Fetch the remote branch (read-only; safe).
	if ! fetch_source; then
		err "Failed to fetch origin/${REPO_BRANCH}. Check network or BHP_REPO_URL."
		pause; return
	fi

	# 3. Determine local vs remote state and show a preview.
	local status; status="$(git_update_status)"
	clear
	print_logo
	printf '\n'
	print_update_preview "$status"
	printf '\n'

	# 4. Decide how to proceed based on status.
	case "$status" in
		up-to-date)
			if ! ask_yes_no "Already up to date. Rebuild/reinstall anyway?" "n"; then
				info "Update cancelled; nothing to do."
				pause; return
			fi
			;;
		behind\ remote)
			if ! ask_yes_no "Update now?" "y"; then
				info "Update cancelled."
				pause; return
			fi
			if ! apply_update; then
				err "git pull --ff-only failed. Not building; service untouched."
				err "Inspect the checkout at ${SRC_DIR}."
				pause; return
			fi
			;;
		ahead\ of\ remote)
			warn "Local checkout is ahead of origin/${REPO_BRANCH}."
			warn "Updating may discard local state if forced. This tool will NOT force."
			if ! ask_yes_no "Rebuild from the current local checkout anyway?" "n"; then
				info "Update cancelled. Inspect ${SRC_DIR} if this is unexpected."
				pause; return
			fi
			# Rebuild from current local checkout without changing git state.
			;;
		diverged)
			err "Local checkout has DIVERGED from origin/${REPO_BRANCH}."
			err "Refusing to continue automatically to avoid losing work."
			err "Inspect and reconcile manually: ${SRC_DIR}"
			pause; return
			;;
		*)
			err "Could not determine update status. Inspect ${SRC_DIR}."
			pause; return
			;;
	esac

	# Update the manager script itself from the freshly prepared checkout so the
	# improved UI takes effect. This is independent of the daemon build and does
	# not touch the running service or config.
	manager_updated="no"
	if install_manager_atomic; then
		manager_updated="yes"
	fi

	backup_config

	# Capture a CLEAN backup path for reliable rollback (no UI text on stdout).
	local prev_backup=""
	prev_backup="$(backup_binary_path)"
	if [[ -n "$prev_backup" ]]; then
		ok "Binary backed up to ${prev_backup}"
	else
		warn "No previous binary backup available before update."
	fi

	# Record service state before we touch anything.
	local was_active="no"
	if systemctl is-active --quiet "$SERVICE_NAME"; then
		was_active="yes"
	fi

	# Build must happen before stopping the service. The checkout is already
	# at the desired commit (fast-forwarded above, or intentionally local).
	local built=""
	if ! built="$(build_binary)"; then
		err "Build failed. Current binary left untouched; service not stopped."
		pause; return
	fi

	info "Build succeeded. Installing new binary..."
	if [[ "$was_active" == "yes" ]]; then
		systemctl stop "$SERVICE_NAME" >/dev/null 2>&1 || true
	fi

	install_binary_atomic "$built"
	rm -rf "$(dirname "$built")"

	if [[ "$was_active" == "yes" ]]; then
		systemctl start "$SERVICE_NAME" >/dev/null 2>&1 || true
		if health_check; then
			ok "Update completed successfully."
			info "Installed version: $(binary_version)"
		else
			err "Update failed health check; rolling back to previous binary."
			if [[ -n "$prev_backup" && -f "$prev_backup" ]]; then
				install -m 0755 "$prev_backup" "${BIN_DAEMON}.new"
				mv -f "${BIN_DAEMON}.new" "$BIN_DAEMON"
				recreate_symlink
				systemctl restart "$SERVICE_NAME" >/dev/null 2>&1 || true
				if health_check; then
					warn "Update failed health check; rolled back to previous binary."
				else
					err "Rollback restart also failed. Inspect: journalctl -u ${SERVICE_NAME} -n 50 --no-pager"
				fi
			else
				err "No previous binary backup available to roll back to."
			fi
		fi
	else
		# Service was stopped before; leave it stopped. No health check/rollback.
		ok "Update completed successfully."
		info "Service was previously stopped and was left stopped."
		info "Installed version: $(binary_version)"
	fi
	if [[ "$manager_updated" == "yes" ]]; then
		info "The manager script was updated."
	fi
	pause
	# Offer a self-restart only now that the daemon update / rollback flow has
	# fully completed. This is the last thing do_update does before returning to
	# the menu, so it never interrupts a build, install, or rollback.
	maybe_restart_manager
}

# maybe_restart_manager: if the manager script was refreshed during this update,
# offer to re-exec the freshly installed manager so the new UI takes effect in
# the current session. Must only be called after all update work has finished.
maybe_restart_manager() {
	if [[ "${manager_updated:-no}" == "yes" ]]; then
		printf '\n'
		info "Manager was updated."
		if ask_yes_no "Restart bhp now to use the updated manager UI?" "y"; then
			# Reset so a failed exec does not loop on the next menu return.
			manager_updated="no"
			exec "$BIN_MANAGER" || warn "Could not restart bhp automatically. Exit and run 'bhp' again to use the updated UI."
		fi
	fi
}

# --------------------------------------------------------------------------- #
# Install / Repair
# --------------------------------------------------------------------------- #
write_service_unit() {
	local src_unit="${SRC_DIR}/packaging/backhaulplus.service"
	if [[ -f "$src_unit" ]]; then
		install -m 0644 "$src_unit" "$SERVICE_UNIT"
	else
		cat > "$SERVICE_UNIT" <<EOF
[Unit]
Description=BackhaulPlus tunnel service
Documentation=https://github.com/codeTide/BackhaulPlus
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
ExecStart=${BIN_DAEMON} -c ${CONFIG_FILE}
WorkingDirectory=${CONFIG_DIR}
Restart=always
RestartSec=3
LimitNOFILE=1048576
KillSignal=SIGTERM
TimeoutStopSec=20

[Install]
WantedBy=multi-user.target
EOF
	fi
	systemctl daemon-reload
}

do_install_repair() {
	require_root || { pause; return; }
	info "Ensuring directories exist..."
	install -d -m 0755 "$CONFIG_DIR" "$STATE_DIR" "$SRC_DIR"
	install -d -m 0750 "$BACKUP_DIR"

	info "Reinstalling systemd unit..."
	write_service_unit
	ok "systemd unit refreshed and daemon reloaded."

	# Ensure manager exists (copy self into place if missing/outdated path).
	if [[ -f "${SRC_DIR}/scripts/bhp" ]]; then
		install -m 0755 "${SRC_DIR}/scripts/bhp" "$BIN_MANAGER"
		ok "Manager ensured at ${BIN_MANAGER}"
	elif [[ ! -f "$BIN_MANAGER" ]]; then
		warn "Manager source not found; cannot (re)install ${BIN_MANAGER} automatically."
	fi

	# Ensure symlink.
	if [[ -f "$BIN_DAEMON" ]]; then
		recreate_symlink
		ok "Compatibility symlink ensured: ${BIN_COMPAT} -> ${BIN_DAEMON}"
	fi

	if [[ ! -f "$BIN_DAEMON" || ! -d "${SRC_DIR}/.git" ]]; then
		warn "Source checkout or binary is missing."
		if ask_yes_no "Run update/build now to (re)build the binary?" "y"; then
			if command -v go >/dev/null 2>&1 && command -v git >/dev/null 2>&1; then
				update_source
				local built=""
				if built="$(build_binary)"; then
					install_binary_atomic "$built"
					rm -rf "$(dirname "$built")"
					ok "Binary built and installed."
				else
					err "Build failed."
				fi
			else
				err "git and go are required to build. Install them and retry."
			fi
		fi
	fi
	ok "Install / Repair complete."
	pause
}

# --------------------------------------------------------------------------- #
# Service submenu
# --------------------------------------------------------------------------- #
svc_action() {
	local action="$1"
	require_root || return
	if systemctl "$action" "$SERVICE_NAME"; then
		ok "systemctl ${action} ${SERVICE_NAME} succeeded."
	else
		err "systemctl ${action} ${SERVICE_NAME} failed."
	fi
}

menu_service() {
	while true; do
		clear
		print_panel "Service"
		printf '\n'
		menu_item 1 "Start"           "$C_GREEN"
		menu_item 2 "Stop"            "$C_YELLOW"
		menu_item 3 "Restart"         "$C_BOLD"
		menu_item 4 "Status"          "$C_BOLD"
		menu_item 5 "Enable on boot"  "$C_BOLD"
		menu_item 6 "Disable on boot" "$C_YELLOW"
		menu_item 0 "Back"            "$C_DIM"
		printf '\n'
		sep
		read -r -p "$(printf ' %sEnter your choice [0-6]:%s ' "$C_BOLD" "$C_RESET")" choice || choice="0"
		case "$choice" in
			1) svc_action start; pause ;;
			2) svc_action stop; pause ;;
			3) svc_action restart; pause ;;
			4) systemctl status "$SERVICE_NAME" --no-pager || true; pause ;;
			5) svc_action enable; pause ;;
			6) svc_action disable; pause ;;
			0) return ;;
			*) warn "Invalid choice."; pause ;;
		esac
	done
}

# --------------------------------------------------------------------------- #
# Config submenu
# --------------------------------------------------------------------------- #
config_edit() {
	require_root || return
	local editor="${EDITOR:-}"
	if [[ -z "$editor" ]]; then
		if command -v nano >/dev/null 2>&1; then editor="nano"
		elif command -v vi >/dev/null 2>&1; then editor="vi"
		else err "No editor found. Set \$EDITOR or install nano/vi."; return; fi
	fi
	[[ -f "$CONFIG_FILE" ]] || warn "Config does not exist yet; a new file will be created."
	"$editor" "$CONFIG_FILE"
}

config_show() {
	if [[ ! -f "$CONFIG_FILE" ]]; then
		warn "No config at ${CONFIG_FILE}."
		return
	fi
	if command -v less >/dev/null 2>&1; then
		less "$CONFIG_FILE"
	else
		cat "$CONFIG_FILE"
	fi
}

menu_config() {
	while true; do
		clear
		print_panel "Config"
		printf '\n'
		menu_item 1 "Edit config"      "$C_BOLD"
		menu_item 2 "Show config"      "$C_BOLD"
		menu_item 3 "Show config path" "$C_BOLD"
		menu_item 4 "Backup config"    "$C_BOLD"
		menu_item 0 "Back"             "$C_DIM"
		printf '\n'
		sep
		read -r -p "$(printf ' %sEnter your choice [0-4]:%s ' "$C_BOLD" "$C_RESET")" choice || choice="0"
		case "$choice" in
			1) config_edit; pause ;;
			2) config_show; pause ;;
			3) printf '%s\n' "$CONFIG_FILE"; pause ;;
			4) require_root && backup_config; pause ;;
			0) return ;;
			*) warn "Invalid choice."; pause ;;
		esac
	done
}

# --------------------------------------------------------------------------- #
# Logs submenu
# --------------------------------------------------------------------------- #
menu_logs() {
	while true; do
		clear
		print_panel "Logs"
		printf '\n'
		menu_item 1 "Live logs"      "$C_BOLD"
		menu_item 2 "Last 100 lines" "$C_BOLD"
		menu_item 3 "Last boot logs" "$C_BOLD"
		menu_item 0 "Back"           "$C_DIM"
		printf '\n'
		sep
		read -r -p "$(printf ' %sEnter your choice [0-3]:%s ' "$C_BOLD" "$C_RESET")" choice || choice="0"
		case "$choice" in
			1) info "Streaming logs (Ctrl+C to stop)..."; journalctl -u "$SERVICE_NAME" -f || true; pause ;;
			2) journalctl -u "$SERVICE_NAME" -n 100 --no-pager || true; pause ;;
			3) journalctl -u "$SERVICE_NAME" -b --no-pager || true; pause ;;
			0) return ;;
			*) warn "Invalid choice."; pause ;;
		esac
	done
}

# --------------------------------------------------------------------------- #
# Backup submenu
# --------------------------------------------------------------------------- #
menu_backup() {
	while true; do
		clear
		print_panel "Backup"
		printf '\n'
		menu_item 1 "Backup config" "$C_BOLD"
		menu_item 2 "Backup binary" "$C_BOLD"
		menu_item 3 "Backup all"    "$C_BOLD"
		menu_item 0 "Back"          "$C_DIM"
		printf '\n'
		sep
		read -r -p "$(printf ' %sEnter your choice [0-3]:%s ' "$C_BOLD" "$C_RESET")" choice || choice="0"
		case "$choice" in
			1) require_root && backup_config; pause ;;
			2) require_root && backup_binary; pause ;;
			3) require_root && backup_all; pause ;;
			0) return ;;
			*) warn "Invalid choice."; pause ;;
		esac
	done
}

# --------------------------------------------------------------------------- #
# Advanced submenu
# --------------------------------------------------------------------------- #
pick_backup() {
	# Args: glob pattern. Prints chosen path on stdout, empty if none/cancel.
	local pattern="$1"
	local -a files=()
	local f
	# Newest first.
	while IFS= read -r f; do files+=("$f"); done < <(ls -1t $pattern 2>/dev/null || true)
	if [[ ${#files[@]} -eq 0 ]]; then
		printf '' ; return
	fi
	{
		printf '\nAvailable backups:\n' >&2
		local i
		for i in "${!files[@]}"; do
			printf '  %d) %s\n' "$((i+1))" "${files[$i]}" >&2
		done
		printf '  0) Cancel\n' >&2
	}
	local sel
	read -r -p "Select: " sel >&2 || sel="0"
	if [[ "$sel" =~ ^[0-9]+$ ]] && (( sel >= 1 && sel <= ${#files[@]} )); then
		printf '%s' "${files[$((sel-1))]}"
	else
		printf ''
	fi
}

adv_rollback_binary() {
	require_root || return
	local chosen; chosen="$(pick_backup "${BACKUP_DIR}/backhaulplus-*")"
	if [[ -z "$chosen" ]]; then warn "No backup selected."; return; fi
	info "Rolling back to ${chosen}"
	systemctl stop "$SERVICE_NAME" >/dev/null 2>&1 || true
	install -m 0755 "$chosen" "${BIN_DAEMON}.new"
	mv -f "${BIN_DAEMON}.new" "$BIN_DAEMON"
	recreate_symlink
	systemctl start "$SERVICE_NAME" >/dev/null 2>&1 || true
	if health_check; then
		ok "Rollback complete; service is running."
	else
		err "Service failed to start after rollback. Inspect: journalctl -u ${SERVICE_NAME} -n 50 --no-pager"
	fi
}

adv_restore_config() {
	require_root || return
	local chosen; chosen="$(pick_backup "${BACKUP_DIR}/config-*.toml")"
	if [[ -z "$chosen" ]]; then warn "No backup selected."; return; fi
	# Back up current config first.
	backup_config
	cp -a "$chosen" "$CONFIG_FILE"
	ok "Restored config from ${chosen}"
	if ask_yes_no "Restart ${SERVICE_NAME} now?" "y"; then
		systemctl restart "$SERVICE_NAME" && ok "Service restarted." || err "Restart failed."
	fi
}

adv_reinstall_service() {
	require_root || return
	write_service_unit
	ok "Rewrote ${SERVICE_UNIT} and ran daemon-reload."
	if ask_yes_no "Enable service on boot?" "y"; then
		systemctl enable "$SERVICE_NAME" >/dev/null 2>&1 && ok "Enabled." || warn "Enable failed."
	fi
	if ask_yes_no "Start/restart service now?" "y"; then
		systemctl restart "$SERVICE_NAME" && ok "Service (re)started." || err "Restart failed."
	fi
}

adv_show_paths() {
	label_value "repo"    "$REPO_URL"     "$C_CYAN"
	label_value "branch"  "$REPO_BRANCH"  "$C_CYAN"
	label_value "daemon"  "$BIN_DAEMON"   "$C_DIM"
	label_value "symlink" "$BIN_COMPAT"   "$C_DIM"
	label_value "manager" "$BIN_MANAGER"  "$C_DIM"
	label_value "config"  "$CONFIG_FILE"  "$C_DIM"
	label_value "source"  "$SRC_DIR"      "$C_DIM"
	label_value "backup"  "$BACKUP_DIR"   "$C_DIM"
	label_value "unit"    "$SERVICE_UNIT" "$C_DIM"
}

adv_uninstall() {
	require_root || return
	warn "This will stop and remove the systemd service and installed binaries."
	if ! ask_yes_no "Proceed with uninstall?" "n"; then
		info "Uninstall cancelled."
		return
	fi

	local keep_data="y"
	if ask_yes_no "Keep config and backups?" "y"; then
		keep_data="y"
	else
		keep_data="n"
	fi

	info "Stopping and disabling service..."
	systemctl stop "$SERVICE_NAME" >/dev/null 2>&1 || true
	systemctl disable "$SERVICE_NAME" >/dev/null 2>&1 || true

	rm -f "$SERVICE_UNIT"
	rm -f "$BIN_DAEMON"
	rm -f "$BIN_COMPAT"
	rm -f "$BIN_MANAGER"
	systemctl daemon-reload
	ok "Removed service unit and installed binaries."

	if ask_yes_no "Remove source checkout at ${SRC_DIR}?" "n"; then
		rm -rf "$SRC_DIR"
		ok "Removed ${SRC_DIR}"
	fi

	if [[ "$keep_data" == "n" ]]; then
		warn "You chose NOT to keep config and backups."
		if ask_yes_no "Really remove ${CONFIG_DIR}?" "n"; then
			rm -rf "$CONFIG_DIR"; ok "Removed ${CONFIG_DIR}"
		fi
		if ask_yes_no "Really remove ${BACKUP_DIR}?" "n"; then
			rm -rf "$BACKUP_DIR"; ok "Removed ${BACKUP_DIR}"
		fi
	else
		info "Kept ${CONFIG_DIR} and ${BACKUP_DIR}."
	fi
	ok "Uninstall finished."
	info "Note: this manager was removed; the menu will exit after this."
}

menu_advanced() {
	while true; do
		clear
		print_panel "Advanced / Recovery"
		printf '\n'
		menu_item 1 "Rollback binary"       "$C_YELLOW"
		menu_item 2 "Restore config backup" "$C_YELLOW"
		menu_item 3 "Reinstall service file" "$C_BOLD"
		menu_item 4 "Show install paths"    "$C_BOLD"
		menu_item 5 "Uninstall"             "$C_RED"
		menu_item 0 "Back"                  "$C_DIM"
		printf '\n'
		sep
		read -r -p "$(printf ' %sEnter your choice [0-5]:%s ' "$C_BOLD" "$C_RESET")" choice || choice="0"
		case "$choice" in
			1) adv_rollback_binary; pause ;;
			2) adv_restore_config; pause ;;
			3) adv_reinstall_service; pause ;;
			4) adv_show_paths; pause ;;
			5) adv_uninstall; pause; [[ ! -f "$BIN_MANAGER" ]] && exit 0 ;;
			0) return ;;
			*) warn "Invalid choice."; pause ;;
		esac
	done
}

# --------------------------------------------------------------------------- #
# Header / main menu
# --------------------------------------------------------------------------- #
# print_panel: compact submenu header (colored separator + title), no logo.
print_panel() {
	local title="$1"
	sep
	printf ' %s%s%s%s\n' "$C_BOLD" "$C_CYAN" "$title" "$C_RESET"
	sep
}

# print_main_header: ASCII logo + colored status block for the main menu.
print_main_header() {
	local status; status="$(service_status)"
	local ver; ver="$(binary_version)"

	print_logo
	printf '\n\n'
	sep
	label_value "Version" "$ver"          "$C_CYAN"
	label_value "Service" "$SERVICE_NAME" "$C_RESET"
	label_value "Status"  "$status"       "$(status_color "$status")"
	label_value "Config"  "$CONFIG_FILE"  "$C_DIM"
	label_value "Binary"  "$BIN_DAEMON"   "$C_DIM"
	label_value "Source"  "$SRC_DIR"      "$C_DIM"
	sep
}

main_menu() {
	while true; do
		clear
		print_main_header
		printf '\n'
		menu_item 1 "Install / Repair" "$C_BOLD"
		menu_item 2 "Update"           "$C_GREEN"
		menu_item 3 "Service"          "$C_BOLD"
		menu_item 4 "Config"           "$C_BOLD"
		menu_item 5 "Logs"             "$C_BOLD"
		menu_item 6 "Backup"           "$C_BOLD"
		menu_item 7 "Advanced"         "$C_YELLOW"
		menu_item 0 "Exit"             "$C_DIM"
		printf '\n'
		sep
		read -r -p "$(printf ' %sEnter your choice [0-7]:%s ' "$C_BOLD" "$C_RESET")" choice || choice="0"
		case "$choice" in
			1) do_install_repair ;;
			2) do_update ;;
			3) menu_service ;;
			4) menu_config ;;
			5) menu_logs ;;
			6) menu_backup ;;
			7) menu_advanced ;;
			0) printf 'Bye.\n'; exit 0 ;;
			*) warn "Invalid choice."; pause ;;
		esac
	done
}

# --------------------------------------------------------------------------- #
# Entry point - interactive only
# --------------------------------------------------------------------------- #
# Handle Ctrl+C gracefully: return to a clean prompt rather than a traceback.
trap 'printf "\n"; exit 130' INT

if [[ $# -gt 0 ]]; then
	printf '%sbhp is interactive only; opening menu...%s\n' "$C_YELLOW" "$C_RESET"
	sleep 1
fi

# Most actions need root; require it up front for a predictable experience.
if [[ "$(id -u)" -ne 0 ]]; then
	warn "Some actions require root. For full functionality run: sudo bhp"
	sleep 1
fi

main_menu
